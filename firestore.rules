rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Orders: anyone can submit and read/update (admin panel runs client-side)
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Applications: anyone can apply, admin panel reads/reviews
    match /applications/{applicationId} {
      allow read, write: if true;
    }

    // Announcements: anyone can read the active banner, admin panel manages CRUD
    match /announcements/{announcementId} {
      allow read, write: if true;
    }

    // Workers: anyone can read/write (verification is done cryptographically client-side)
    match /workers/{workerId} {
      allow read, write: if true;
    }
  }
}
